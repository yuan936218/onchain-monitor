# ================================================================
# OPTION A: Use Cloudflare Worker proxy (recommended for China)
# ================================================================
# Deploy proxy-worker.js to Cloudflare Workers (free, see README)
# Then set your Worker URL here:
# ETHERSCAN_BASE_URL=https://eth-proxy.your-username.workers.dev

# ================================================================
# OPTION B: Direct connection (if you have a VPN/HTTP proxy)
# ================================================================
# HTTPS_PROXY=http://127.0.0.1:7890

# ================================================================
# Required: Etherscan API Key
# ================================================================
# Get one free at https://etherscan.io/register
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ================================================================
# Optional: Whale Alert API Key
# ================================================================
# Free tier at https://docs.whale-alert.io/
WHALE_ALERT_API_KEY=

# ================================================================
# Optional: Feishu bot notifications
# ================================================================
# Create bot in Feishu group: Settings → Group Bot → Add → Copy Webhook URL
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# ================================================================
# Optional: Threshold overrides
# ================================================================
# THRESHOLD_LARGE_TRANSFER=1000000
# THRESHOLD_EXCHANGE_INFLOW=5000000
